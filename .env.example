# Shopify App — from Dev Dashboard → Settings → Credentials
SHOPIFY_API_KEY=your_client_id_here
SHOPIFY_API_SECRET=your_client_secret_here
SHOPIFY_APP_URL=https://your-render-url.onrender.com
SCOPES=read_orders,read_customers,read_products,write_marketing_events

# Database — Render auto-wires this if you use their Postgres add-on
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
REPLICATE_API_TOKEN=r8_...

# Meta Marketing API
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_PAGE_ID=your_facebook_page_id

# TikTok for Business API
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret

# Social auto-posting aggregator (upload-post.com). Without it, campaigns
# forge content but wait as READY instead of posting.
UPLOADPOST_API_KEY=
