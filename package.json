{
  "name": "marginmonster",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/fetch-ffmpeg.mjs && remix vite:build",
    "dev": "shopify app dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "setup": "prisma generate && prisma db push",
    "start": "remix-serve ./build/server/index.js",
    "worker": "node --loader ts-node/esm worker.ts",
    "prisma": "prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@prisma/client": "^5.16.0",
    "@remix-run/dev": "^2.10.0",
    "@remix-run/node": "^2.10.0",
    "@remix-run/react": "^2.10.0",
    "@remix-run/serve": "^2.10.0",
    "@shopify/app-bridge-react": "^4.1.5",
    "@shopify/polaris": "^13.3.0",
    "@shopify/polaris-icons": "^9.3.0",
    "@shopify/shopify-app-remix": "^3.3.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.0.5",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "isbot": "^4.4.0",
    "prisma": "^5.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ts-node": "^10.9.2"
  },
  "workspaces": []
}
