generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model Shop {
  id          String   @id @default(cuid())
  domain      String   @unique
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Player progression — the arcade XP/level system. XP is awarded server-side
  // for meaningful outcomes (forge, apply, token spend…); level-ups gift tokens.
  xp           Int @default(0)
  level        Int @default(1)
  forgedCount  Int @default(0) // lifetime listings forged
  appliedCount Int @default(0) // lifetime listings applied to the store
  tokensSpent  Int @default(0) // lifetime tokens spent
  // one-shot flash for the global level-up popup: {"level":n,"gift":n}
  pendingLevelUp String?
  // Brand Face — the merchant's signature presenter (avatars.ts id + outfit),
  // pre-cast on every Video Studio visit for cross-campaign consistency
  brandAvatarId      String?
  brandAvatarVariant Int     @default(0)
  // Companion — the merchant's chosen chibi partner (companions.ts id, or
  // "custom" with the forged art stored inline as base64 PNGs; disk on Render
  // is ephemeral so custom art lives in the DB until the R2/S3 track)
  companionId    String?
  companionName  String?
  companionArt   String? // custom base frame (base64 png)
  companionArtB  String? // custom blink frame
  companionArtC  String? // custom cheer frame
  // Social auto-posting via the upload-post aggregator (v1 posting backend;
  // provider-swappable). socialProfileKey = the shop's provider profile id;
  // socialsJson = cached list of platforms the merchant linked
  socialProfileKey String?
  socialsJson      String?
  // Cached profile analytics per linked platform (followers, reach, views,
  // likes, comments, shares, saves) + fetchedAt — refreshed hourly by the
  // worker from the provider's analytics API. Powers the organic Results view.
  socialStatsJson  String?
  // Growth plumbing: when we fired the in-app App Store review request (once,
  // after the first real win) and onboarding first-content + referral state.
  reviewAskedAt    DateTime?
  onboardKickAt    DateTime?
  referralCode     String?   @unique
  referredBy       String?   // referralCode of the shop that referred this one
  referralCreditAt DateTime? // when we granted the referrer's reward
  lastDigestAt     DateTime? // last monthly "here's what we made you" digest
  contactEmail     String?   // store's own contact email (for the digest)

  brandProfile   BrandProfile?
  activePlan     Plan?
  assets         Asset[]
  jobs           Job[]
  adAccounts     AdAccount[]
  campaigns      Campaign[]
  achievements   ShopAchievement[]
  landingPages   LandingPage[]
  questlines     Questline[]
  tokenPurchases TokenPurchase[]
  subscribers        Subscriber[]
  abandonedCheckouts AbandonedCheckout[]
  customerLifecycles CustomerLifecycle[]
}

// One row per PAID token top-up — chargeId is unique so a purchase can never
// be credited twice, no matter how many times the return URL is reloaded.
model TokenPurchase {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  chargeId  String   @unique
  tokens    Int
  amountUsd Int
  createdAt DateTime @default(now())
}

// Campaigns reframed as game Questlines — an automated content-and-posting
// mission with a live objective log, token cost paid upfront, and XP/reward
// milestones. Distinct from Campaign (which models a single platform ad).
model Questline {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  template       String    // template key (questlines.ts)
  name           String    // game name shown to the merchant
  status         String    @default("ACTIVE") // ACTIVE | PAUSED | COMPLETE
  avatarId       String?   // brand face starring in this questline's content
  avatarVariant  Int       @default(0)
  reviewMode     String    @default("REVIEW_FIRST") // REVIEW_FIRST | SET_AND_FORGET
  productTitle   String?
  productImageUrl String?
  objectivesJson String    // [{key,label,type,target,done}]
  scheduleJson   String    @default("{}") // {slots:[{idx,day,date,time,type,spot,productTitle,productImageUrl,status}],weeksAwarded:[]}
  durationDays   Int       @default(30) // monthly segment
  tokenCost      Int       @default(0) // charged upfront on accept
  xpReward       Int       @default(0) // dropped on completion
  progress       Int       @default(0) // 0-100
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([shopId, status])
}

model ShopAchievement {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  key        String
  unlockedAt DateTime @default(now())

  @@unique([shopId, key])
}

model LandingPage {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  slug        String   @unique
  title       String
  productName String
  goal        String   @default("BUY")
  contentJson String   // hero, subhead, benefits[], testimonial, cta, ctaUrl
  published   Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BrandProfile {
  id          String   @id @default(cuid())
  shopId      String   @unique
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // AI-generated brand intelligence
  voiceJson   String   // JSON: tone, vocabulary, values, sample phrases
  visualJson  String   // JSON: primaryColor, accentColor, fontStyle, imageStyle
  productJson String   // JSON: top products, categories, price range, AOV
}

enum PlanType {
  STARTER
  GROWTH
  PRO
  SCALE
}

enum ReviewMode {
  SET_AND_FORGET
  REVIEW_FIRST
}

enum CampaignGoal {
  GROW_SALES
  LAUNCH_PRODUCT
  CLEAR_INVENTORY
  BUILD_AWARENESS
}

model Plan {
  id                String     @id @default(cuid())
  shopId            String     @unique
  shop              Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type              PlanType
  reviewMode        ReviewMode @default(REVIEW_FIRST)
  active            Boolean    @default(true)

  // Add-ons
  adCreativePack    Boolean    @default(false)
  campaignAutopilot Boolean    @default(false)

  // Monthly quotas (seeded from the tier at selection time)
  blogQuota         Int        @default(0)
  videoQuota        Int        @default(0)
  imageQuota        Int        @default(0)

  // Usage in the current billing period
  blogUsed          Int        @default(0)
  videoUsed         Int        @default(0)
  periodStart       DateTime   @default(now())

  // Unified token wallet — every AI action spends from here
  tokensIncluded    Int        @default(0) // monthly allowance from the tier
  tokensUsed        Int        @default(0) // spent this billing period
  tokensExtra       Int        @default(0) // purchased top-up (does not reset)

  // Purchased overage credits
  blogCredits       Int        @default(0)
  imageCredits      Int        @default(0)
  videoCredits      Int        @default(0)

  // Days between auto-published blog posts
  postIntervalDays  Int        @default(3)

  // Only used when the Campaign Autopilot add-on is enabled
  campaignGoal      CampaignGoal @default(GROW_SALES)
  weeklyBudget      Float      @default(0)

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

enum AssetType {
  IMAGE_AD
  VIDEO_AD
  BLOG_POST
  AD_COPY
  EMAIL
}

enum AssetStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
  FAILED
}

model Asset {
  id          String      @id @default(cuid())
  shopId      String
  shop        Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type        AssetType
  status      AssetStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Content
  title       String?
  bodyJson    String      // JSON: varies by type (imageUrl, blogHtml, adCopy, etc.)
  metaJson    String      // JSON: targetProductId, planType, generationPrompt

  campaigns   Campaign[]
}

enum JobType {
  GENERATE_BRAND_PROFILE
  GENERATE_BLOG_POST
  GENERATE_IMAGE_AD
  GENERATE_VIDEO_AD
  GENERATE_AD_COPY
  LAUNCH_CAMPAIGN
  DECISIONING_PASS
  FORGE_COMPANION
  SEND_ABANDONED_CART
  SEND_WELCOME
  SEND_POST_PURCHASE
  SEND_WINBACK
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model Job {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  type        JobType
  status      JobStatus @default(PENDING)
  payload     String    // JSON
  attempts    Int       @default(0)
  lastError   String?
  runAt       DateTime? // scheduled jobs (campaign drip) wait until this time; null = run now
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  processedAt DateTime?
}

enum AdPlatform {
  META
  TIKTOK
}

model AdAccount {
  id              String     @id @default(cuid())
  shopId          String
  shop            Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  platform        AdPlatform
  externalId      String
  name            String
  accessToken     String
  tokenExpiresAt  DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  campaigns       Campaign[]

  @@unique([shopId, platform])
}

enum CampaignStatus {
  DRAFT
  PAUSED
  ACTIVE
  KILLED
  COMPLETED
}

model Campaign {
  id              String         @id @default(cuid())
  shopId          String
  shop            Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  adAccountId     String
  adAccount       AdAccount      @relation(fields: [adAccountId], references: [id])
  assetId         String
  asset           Asset          @relation(fields: [assetId], references: [id])
  platform        AdPlatform
  externalId      String?        // platform campaign ID (null until launched)
  status          CampaignStatus @default(DRAFT)
  budgetCents     Int
  spentCents      Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  metrics         PerformanceMetric[]
}

model PerformanceMetric {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  recordedAt      DateTime @default(now())

  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  spendCents      Int      @default(0)
  revenueCents    Int      @default(0)
  roas            Float    @default(0)
}

// 📧 Email list built by EasyMode's own signup popup (PCD-free — these are
// people who opted in through OUR form, so we own the consent and don't need
// Shopify customer-data approval to email them).
model Subscriber {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  email     String
  source    String   @default("popup") // popup | manual | import
  status    String   @default("subscribed") // subscribed | unsubscribed
  createdAt DateTime @default(now())

  @@unique([shopId, email])
  @@index([shopId])
}

// 🛒 Abandoned checkouts captured from the checkouts webhooks. A delayed
// SEND_ABANDONED_CART job fires ~1h later; if still "pending" (no matching
// order) and email is connected, the AI recovery email sends. Webhook payloads
// carry customer email → this only receives data once PCD approval lands.
model AbandonedCheckout {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  checkoutToken String
  email         String?
  recoveryUrl   String?
  itemsJson     String   @default("[]") // [{title,image,qty}]
  totalPrice    String?
  status        String   @default("pending") // pending | recovered | emailed | skipped
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shopId, checkoutToken])
  @@index([shopId, status])
}

// 💌 Win-back timing. Each order upserts lastOrderAt and schedules a SEND_WINBACK
// job at +45d carrying that order's timestamp; the job only fires if lastOrderAt
// hasn't advanced (i.e. they didn't order again), so only the latest order's
// timer ever sends. No periodic sweep needed.
model CustomerLifecycle {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  email       String
  lastOrderAt DateTime
  updatedAt   DateTime @updatedAt

  @@unique([shopId, email])
  @@index([shopId])
}
